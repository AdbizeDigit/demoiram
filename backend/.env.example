# Database Configuration
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# OpenAI API Key (optional - for real AI responses)
OPENAI_API_KEY=your-openai-api-key-here

# DeepSeek API Key (for custom chatbots)
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# News APIs for Scrapping Intelligence
NEWS_API_KEY=your-newsapi-key-here
GNEWS_API_KEY=your-gnews-key-here
NEWSDATA_API_KEY=your-newsdata-key-here

# Server Configuration
PORT=5000

# Python Service
PYTHON_SERVICE_PORT=5001
