{
  "name": "demo-platform-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node --watch server.js\" \"cd python-service && python app.py\"",
    "start": "concurrently \"node server.js\" \"cd python-service && python app.py\"",
    "server": "node server.js",
    "python": "cd python-service && python app.py",
    "init-db": "node scripts/init-db.js",
    "migrate": "node scripts/add-custom-chatbot-column.js",
    "init-agent": "node scripts/init-agent-tables.js",
    "migrate-opportunity": "node scripts/add-opportunity-detection-column.js",
    "init-automation": "node scripts/init-automation-tables.js",
    "init-seller": "node scripts/init-seller-tables.js",
    "postinstall": "echo 'Chrome will be downloaded at runtime to persistent storage'"
  },
  "dependencies": {
    "@getbrevo/brevo": "^5.0.1",
    "@google/generative-ai": "^0.24.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.1.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "imapflow": "^1.2.16",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.9.4",
    "mongoose": "^8.1.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.2",
    "openai": "^4.28.0",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "puppeteer": "^24.40.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-adblocker": "^2.13.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "qrcode": "^1.5.4",
    "socket.io": "^4.6.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.3"
  }
}
